<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <!-- Wrap content in this LinearLayout with vertical orientation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Episode Title -->
            <TextView
                android:id="@+id/episodeTitleTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Previous and Next Episode buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/previousEpisodeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Previous Episode"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/nextEpisodeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next Episode"/>
            </LinearLayout>

            <!-- Container for dynamic download buttons -->
            <LinearLayout
                android:id="@+id/downloadContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"/>

            <!-- TextView for download URLs (if needed) -->
            <TextView
                android:id="@+id/downloadUrlsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:padding="16dp"/>

            <!-- Resolution container for dynamic buttons -->
            <LinearLayout
                android:id="@+id/resolutionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
